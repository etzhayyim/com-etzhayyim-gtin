{:description
 "Global canonical product registry for GTIN, JAN, UPC, and EAN identified trade items. Resolves path-based product DIDs, validates GS1-style identifiers, and serves as the upstream identity layer for comparison, commerce, and inventory actors.",
 :performerType "service",
 :capabilities
 ["graph.query"
  "graph.write"
  "agent.chat"
  "agent.invoke"
  "derive:social"],
 :heartbeatRequired true,
 :edge "sveltekit-proxy",
 :convoSystemPrompt
 "You are the GTIN global product registry actor. You manage canonical trade-item identities for GTIN, JAN, UPC, and EAN codes. Resolve one product DID per canonical code unless explicitly split by pack size or market-specific packaging. You do not own merchant-specific price or inventory; those belong to downstream offer actors such as kakaku.etzhayyim.com. Preserve alias links between JAN, UPC, EAN, and GTIN-14 forms when they identify the same trade item.",
 :standardStatus "required",
 :domainKnowledgeRequired true,
 :uiType "yoro",
 :displayName "GTIN Global Product Registry",
 :name "gtin",
 :legacyExecutionTier "T1",
 :governance {:classification "internal", :raci "responsible"},
 :requiredLoops ["shinka" "koji" "kyumei" "domain-knowledge"],
 :jsonld/context "https://etzhayyim.com/ns/actor/v1",
 :nanoid "gt1n4k7m",
 :requiredCollections
 ["com.etzhayyim.apps.standard.shinkaEvolution"
  "com.etzhayyim.apps.standard.shinkaKnowledge"],
 :standardRule "per-did-kyumei-shinka-autonomy@2026-04-13",
 :triggers
 {:subscribeRepos
  {:collections
   ["com.etzhayyim.gtin.product"
    "com.etzhayyim.gtin.alias"
    "com.etzhayyim.gtin.brand"
    "com.etzhayyim.gtin.category"]}},
 :actor/did "did:web:etzhayyim.com:actor:gtin",
 :actor/legacy-did "did:web:gtin.etzhayyim.com",
 :actors
 [{:description
   "ISCO 2434 — canonical product identity, naming, category assignment",
   :displayName "Catalog",
   :path "actor:catalog"}
  {:description
   "ISCO 3359 — GTIN, JAN, UPC, EAN normalization and alias resolution",
   :displayName "Identifier Registry",
   :path "actor:identifierRegistry"}
  {:description
   "ISCO 2431 — brand normalization and portfolio association",
   :displayName "Brand Registry",
   :path "actor:brandRegistry"}
  {:description
   "ISCO 3119 — validation, duplicate merge review, packaging split review",
   :displayName "Quality",
   :path "actor:quality"}],
 :runtime "k8s-langserver",
 :pipelines
 [{:steps
   [{:args
     {:message
      "Normalize GTIN-family identifiers for product record $input.record. Return compact JSON with canonicalGTIN, aliases, and validation issues."},
     :fn "agent.chat",
     :id "normalizeIdentifiers"}
    {:args {:template "GTIN product updated: $input.record.productId"},
     :fn "derive:social",
     :id "announce"}],
   :trigger
   {:collections ["com.etzhayyim.gtin.product"],
    :type "subscribeRepos"}}
  {:steps
   [{:args
     {:sql
      "MATCH (p:GtinProduct) WHERE p.product_id = $input.record.productId OR p.gtin = $input.record.gtin OR p.jan = $input.record.gtin OR p.upc = $input.record.gtin OR p.ean = $input.record.gtin RETURN p.product_id AS productId, p.did AS did, p.name AS name, p.brand AS brand, p.gtin AS gtin, p.jan AS jan, p.upc AS upc, p.ean AS ean, p.pack_size AS packSize, p.category AS category LIMIT 1"},
     :fn "graph.query",
     :id "lookupProduct"}],
   :trigger {:nsid "com.etzhayyim.gtin.lookupProduct", :type "xrpc"}}
  {:steps
   [{:args
     {:sql
      "MATCH (n) WHERE n.repo = $did RETURN count(n) AS nodeCount LIMIT 1"},
     :fn "graph.query",
     :id "coverageNodes"}
    {:args
     {:params {:nodeCount "$coverageNodes.rows[0].nodeCount"},
      :template
      "MERGE (c:ActorCoverageSnapshot {actorDid: $did, bucket: '6h', actorName: 'gtin', nanoid: 'gt1n4k7m', nodeCount: $nodeCount, repo: $did, collection: 'com.etzhayyim.gtin.coverageSnapshot', status: 'active'})"},
     :depends_on ["coverageNodes"],
     :fn "graph.write",
     :id "coverageSnapshot"}],
   :trigger {:cron "0 */6 * * *", :type "cron"}}],
 :complianceDocs
 ["90-docs/rules/compliance/per-did-kyumei-shinka-autonomy.md"
  "90-docs/platform/260403-live-data-kyumei-shinka-consolidated.md"],
 :profile
 {:agentType "autonomous",
  :capabilities
  ["register-product"
   "resolve-product"
   "validate-gtin"
   "lookup-by-barcode"
   "merge-aliases"
   "publish-product"],
  :description
  "Canonical worldwide trade item registry keyed by GTIN-family identifiers.",
  :displayName "GTIN Global Product Registry",
  :isBot true,
  :operator "etzhayyim.co.jp"}}
